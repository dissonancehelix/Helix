{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Helix Measurement Layer",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string"
      },
      "theta": {
        "type": "number"
      },
      "x": {
        "type": "number"
      },
      "units": {
        "type": "string"
      },
      "dimensionless_form": {
        "type": "string"
      },
      "phi": {
        "type": "number"
      },
      "source_field_paths": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "confidence": {
        "type": "string",
        "enum": [
          "LOW",
          "MED",
          "HIGH"
        ]
      }
    },
    "required": [
      "name",
      "theta",
      "x",
      "units"
    ]
  }
}