# -------------------------------------------------------------------
# Helix Boundary Enforcement: Ignored Data & Bloat
# -------------------------------------------------------------------

# Raw provenance is local by default. Keep only pointer docs/manifests.
archive/raw/**
!archive/raw/
!archive/raw/README.md

# Bulky migrated review/history outputs.
archive/analyses/loose_images/
archive/analyses/attraction_images/

# Core sensor outputs.
core/reports/workstation/workstation_snapshot_*.json
core/reports/workstation/workstation_snapshot_*.md

# Domain vendor mirrors and local source trees.
domains/*/vendor/**
!domains/*/vendor/
!domains/*/vendor/README.md
domains/music/tools/foobar-spatial-dsp/vgmspc/

# Heavy domain-local data, caches, and generated pipeline outputs.
domains/music/data/derived/music/library/
domains/music/data/derived/music/phase6/
domains/music/data/derived/music/metadata/lastfmstats-*.json
domains/music/data/derived/music/metadata/*playcount*.json
domains/music/data/derived/music_pipeline/
domains/music/data/derived/atlas_staging/
domains/games/data/derived/games/steamspy_cache/
domains/games/data/derived/games_pipeline/
domains/language/data/derived/language/ud_cache/
domains/language/data/derived/language_pipeline/
domains/trails/data/derived/trails/retrieval/index/

# Nested repos are provenance, not Helix structure.
**/.git/

# Quarantine keeps manifests in git; bulky staged material remains local.
quarantine/**
!quarantine/
!quarantine/README.md
!quarantine/2026-04-27-workspace-refactor/
!quarantine/2026-04-27-workspace-refactor/MIGRATION_MANIFEST.md
!quarantine/2026-04-28-domain-prune/
!quarantine/2026-04-28-domain-prune/MIGRATION_MANIFEST.md

# Heavy files and binaries.
*.parquet
*.csv
*.tsv
*.db
*.sqlite
*.sqlite3
*.jsonl
*.mp3
*.flac
*.wav
*.spc
*.vgz
*.vgm
*.exe
*.dll
*.zip

# OS and Python tooling.
.DS_Store
Thumbs.db
.pytest_cache/
__pycache__/
**/__pycache__/
*.pyc
.env
.venv/
venv/
node_modules/

# Local editor/agent state.
.vscode/
.claude/

# -------------------------------------------------------------------
# Exceptions: Load-Bearing Structure
# -------------------------------------------------------------------

!archive/migrations/
!archive/migrations/**
!domains/*/README.md
!domains/*/manifest.yaml
!domains/*/model/**
!domains/*/tools/**
!domains/*/labs/**
!domains/*/reports/**
!domains/*/data/
!domains/*/data/normalized/
!domains/*/data/derived/
!core/**
!labs/**

# Final bloat guards after broad structure exceptions.
archive/raw/**
!archive/raw/
!archive/raw/README.md
domains/*/vendor/**
!domains/*/vendor/
!domains/*/vendor/README.md
domains/music/tools/foobar-spatial-dsp/vgmspc/
domains/music/data/derived/music/library/
domains/music/data/derived/music/phase6/
domains/music/data/derived/music/metadata/lastfmstats-*.json
domains/music/data/derived/music/metadata/*playcount*.json
domains/music/data/derived/music_pipeline/
domains/music/data/derived/atlas_staging/
domains/games/data/derived/games/steamspy_cache/
domains/language/data/derived/language/ud_cache/
domains/trails/data/derived/trails/retrieval/index/

*.parquet
*.csv
*.tsv
*.db
*.sqlite
*.sqlite3
*.jsonl
