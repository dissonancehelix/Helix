# -------------------------------------------------------------------
# Helix Boundary Enforcement: Ignored Data & Bloat
# -------------------------------------------------------------------

# Local-only evidence rooms. Never publish raw drops or archives.
archive/**
inbox/**
# Core sensor outputs.
core/reports/workstation/workstation_snapshot_*.json
core/reports/workstation/workstation_snapshot_*.md

# Domain vendor mirrors and local source trees.
domains/*/vendor/**
!domains/*/vendor/
!domains/*/vendor/README.md
domains/*/tools/toolkits/**
!domains/*/tools/toolkits/
!domains/*/tools/toolkits/README.md
domains/*/tools/*/toolkits/**
!domains/*/tools/*/toolkits/
!domains/*/tools/*/toolkits/README.md
domains/music/tools/spatial_dsp/dist_new/

# Heavy domain-local data, caches, and generated pipeline outputs.
domains/music/data/library/catalog/
domains/music/data/library/phase6/
domains/music/data/library/metadata/lastfmstats-*.json
domains/music/data/library/metadata/*playcount*.json
domains/music/data/pipeline/
domains/games/data/pipeline/steamspy_cache/
domains/language/data/corpora/ud_cache/
domains/language/data/corpora/
domains/trails/data/pipeline/retrieval/index/

# Nested repos are provenance, not Helix structure.
**/.git/

# Heavy files and binaries.
*.parquet
*.csv
*.tsv
*.db
*.sqlite
*.sqlite3
*.jsonl
*.mp3
*.flac
*.wav
*.spc
*.vgz
*.vgm
*.exe
*.dll
*.zip

# OS and Python tooling.
.DS_Store
Thumbs.db
.pytest_cache/
__pycache__/
**/__pycache__/
*.pyc
.env
.venv/
venv/
node_modules/

# Local editor/agent state.
.vscode/
.claude/

