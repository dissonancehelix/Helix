# Runtime directory (local, non-architectural)
runtime/cache/
runtime/tmp/
runtime/claude/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Temp / logs
*.log
*.tmp

# Virtual environments
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/

# Local experiment outputs
experiments/output/
/05_applications/eft/

# ── Dataset layer: processed outputs (all pipeline-generated, never committed) ──
labs/datasets/music/processed/
labs/datasets/language/processed/
labs/datasets/agents/processed/
!labs/datasets/music/processed/**/.gitkeep
!labs/datasets/language/processed/**/.gitkeep

# ── Execution layer: run artifacts and archives ──
execution/runs/*/archive/
execution/runs/*.zip
execution/runs/*.tar.gz
execution/runs/symbolic_scores/
# Large per-run output JSONs (not probe_result.json)
execution/runs/*/*_catalog.json
execution/runs/*/*_rankings.json
execution/runs/*/*_registry.json
execution/runs/*/wikidata_*.json
execution/logs/reports/*.json

# ── Atlas: generated registries (rebuilt by COMPILE_ATLAS) ──
codex/atlas/entities/registry.json
codex/atlas/entities/entity_graph.json
codex/atlas/invariants/invariant_*_[0-9]*.json

# ── Source code repos with their own git history ──
# These are substrate language references stored as plain directories (not submodules)
codex/library/music/source/github/
codex/library/music/source/code/*/.git/

# ── Binary / rendered outputs ──
*.nrg
*.bin
*.iso
codex/library/music/source/audio/
codex/library/music/source/midi/

# ── Music Library: generated substrate (all pipeline-generated, never committed) ──
codex/library/music/album/
codex/library/music/artist/
!codex/library/music/album/**/*.gitkeep
!codex/library/music/artist/**/*.gitkeep
!codex/library/music/INGESTION.md
!codex/library/music/.compiler_manifest.json
!codex/library/music/.gitkeep
