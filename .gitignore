# -------------------------------------------------------------------
# Helix Boundary Enforcement: Ignored Data & Bloat
# -------------------------------------------------------------------

# Raw provenance is local by default. Keep only pointer docs/manifests.
archive/raw/**
!archive/raw/
!archive/raw/README.md

# Bulky migrated review/history outputs.
archive/analyses/loose_images/
archive/analyses/attraction_images/

# Core sensor outputs.
core/reports/workstation/workstation_snapshot_*.json
core/reports/workstation/workstation_snapshot_*.md

# Domain vendor mirrors and local source trees.
domains/*/vendor/**
!domains/*/vendor/
!domains/*/vendor/README.md
domains/*/tools/toolkits/**
!domains/*/tools/toolkits/
!domains/*/tools/toolkits/README.md
domains/*/tools/*/toolkits/**
!domains/*/tools/*/toolkits/
!domains/*/tools/*/toolkits/README.md
domains/music/tools/spatial_dsp/dist_new/

# Heavy domain-local data, caches, and generated pipeline outputs.
domains/music/data/library/catalog/
domains/music/data/library/phase6/
domains/music/data/library/metadata/lastfmstats-*.json
domains/music/data/library/metadata/*playcount*.json
domains/music/data/pipeline/
domains/games/data/pipeline/steamspy_cache/
domains/language/data/corpora/ud_cache/
domains/language/data/corpora/
domains/trails/data/pipeline/retrieval/index/

# Nested repos are provenance, not Helix structure.
**/.git/

# Inbox is a local drop zone. Track only the sorter contract.
inbox/**
!inbox/
!inbox/README.md

# Heavy files and binaries.
*.parquet
*.csv
*.tsv
*.db
*.sqlite
*.sqlite3
*.jsonl
*.mp3
*.flac
*.wav
*.spc
*.vgz
*.vgm
*.exe
*.dll
*.zip

# OS and Python tooling.
.DS_Store
Thumbs.db
.pytest_cache/
__pycache__/
**/__pycache__/
*.pyc
.env
.venv/
venv/
node_modules/

# Local editor/agent state.
.vscode/
.claude/

# -------------------------------------------------------------------
# Exceptions: Load-Bearing Structure
# -------------------------------------------------------------------

!archive/migrations/
!archive/migrations/**
!domains/*/README.md
!domains/*/manifest.yaml
!domains/*/model/**
!domains/*/tools/**
!domains/*/labs/**
!domains/*/reports/**
!domains/*/data/
!domains/*/data/
!core/**
!labs/**

# Final bloat guards after broad structure exceptions.
archive/raw/**
!archive/raw/
!archive/raw/README.md
domains/*/vendor/**
!domains/*/vendor/
!domains/*/vendor/README.md
domains/*/tools/toolkits/**
!domains/*/tools/toolkits/
!domains/*/tools/toolkits/README.md
domains/*/tools/*/toolkits/**
!domains/*/tools/*/toolkits/
!domains/*/tools/*/toolkits/README.md
domains/music/tools/spatial_dsp/dist_new/
domains/music/data/library/catalog/
domains/music/data/library/phase6/
domains/music/data/library/metadata/lastfmstats-*.json
domains/music/data/library/metadata/*playcount*.json
domains/music/data/pipeline/
domains/games/data/pipeline/steamspy_cache/
domains/language/data/corpora/ud_cache/
domains/trails/data/pipeline/retrieval/index/

*.parquet
*.csv
*.tsv
*.db
*.sqlite
*.sqlite3
*.jsonl
*.mp3
*.flac
*.wav
*.spc
*.vgz
*.vgm
*.exe
*.dll
*.zip
*.pyc
