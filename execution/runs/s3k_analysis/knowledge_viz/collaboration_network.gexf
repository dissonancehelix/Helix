        <viz:size value="10" />
      </node>
      <node id="composer:jun_senoue" label="Jun Senoue">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="One of the few Sega of Japan employees to confirm Jackson's involvement in Sonic the Hedgehog 3 ." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="30" />
      </node>
      <node id="composer:yoshiaki_kashima" label="Yoshiaki Kashima">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Tasked with creating Sonic the Hedgehog 3' s music driver." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:brad_buxer" label="Brad Buxer">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Composer and one of Michael Jackson's closest professional collaborators at the time. One of three members of Jackson's sound team to confirm the artist's involvement in the project." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
