    <nodes>
      <node id="composer:masayuki_nagao" label="Masayuki Nagao">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Originally employed at Sega, Masayuki Nagao was preparing to take a new job at Opus Corp., resulting in the company receiving a &quot;Sound Special Thanks&quot; credit." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:tatsuyuki_maeda" label="Tatsuyuki Maeda">
        <attvalues>
