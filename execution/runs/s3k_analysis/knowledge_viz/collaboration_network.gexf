        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:tokuhiko_uwabo" label="Tokuhiko Uwabo">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Responsible for managing the game's sound development, which entailed assigning Sega staff to production work and contracting outside composers; he confirms he did not compose for the soundtrack itself." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:sachio_ogawa" label="Sachio Ogawa">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="" />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:masaru_setsumaru" label="Masaru Setsumaru">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="One of the few Sega of Japan employees to confirm Jackson's involvement in Sonic the Hedgehog 3 ." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:tomonori_sawada" label="Tomonori Sawada">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="" />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:yukifumi_makino" label="Yukifumi Makino">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Two jingles previously composed by Yukifumi Makino for the original Sonic the Hedgehog were included in Sonic the Hedgehog 3 and Sonic &amp; Knuckles ." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:miyoko_takaoka" label="Miyoko Takaoka">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Credited under Cube Corp., the sound production company she was contracted through. Between her and fellow Cube composer Masanori Hikichi, they created a total of eight tracks for the project." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:masanori_hikichi" label="Masanori Hikichi">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Credited under Cube Corp., the sound production company he was contracted through. Between him and fellow Cube composer Miyoko Takaoka, they created a total of eight tracks for the project." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:masanori_nakayama" label="Masanori Nakayama">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Received a &quot;Sound Special Thanks&quot; for an unknown contribution." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:michael_jackson" label="Michael Jackson">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="An American pop music artist who became involved in the composition of Sonic the Hedgehog 3' s soundtrack relatively late in development, bringing a number of members of his personal sound team to the project." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:c_cirocco_jones" label="C. Cirocco Jones">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="One of three members of Jackson's sound team to confirm the artist's involvement in the project." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:mayumi_nina_sakazaki" label="Mayumi Nina Sakazaki ()">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Michael Jackson's long-time Japanese coordinator, responsible for assisting the artist while working in the country. Receives a &quot;special thanks&quot; credit." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:bruce_connole" label="Bruce Connole">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Worked alongside bassist Damon Doiron, drummer Steve Golladay, and keyboardist Brad Buxer as guitarist and vocalist for new wave band The Jetzons . Part of a composition he worked on with Buxer, &quot;Hard Times,&quot; was the basis for Ice Cap Zone's theme." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:howard_drossin" label="Howard Drossin">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="STI's in-house composer. Recalls being called into the project last minute to create several jingles for Sonic 3 , most of which would go unused until the release of Sonic &amp; Knuckles . Received a &quot;Sound Special Thanks&quot; in Sonic 3' s credits." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:roger_hector" label="Roger Hector">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Responsible for both hiring and firing Jackson from the project, as well as assigning Howard Drossin to the project late in development. Hector was the first person within Sega to confirm Jackson's involvement." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:hisaki_nimiya" label="Hisaki Nimiya">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Coordinator" />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:hisashi_suzuki" label="Hisashi Suzuki">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Sega of Japan executive, director, and engineer. The Sega representative who worked most closely with Michael Jackson during his past collaborations with the company. Suzuki was Jackson's primary point of contact for Sega, and the two reputedly developed a close friendship over the years." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
      <node id="composer:shigeaki_irie" label="Shigeaki Irie">
        <attvalues>
          <attvalue for="0" value="composer" />
          <attvalue for="1" value="Ported the music of Sonic the Hedgehog 3 and Sonic &amp; Knuckles to the Sonic &amp; Knuckles Collection." />
        </attvalues>
        <viz:color r="78" g="121" b="167" a="1.0" />
        <viz:size value="10" />
      </node>
