__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# ── Virtual environments ──
.venv/
venv/
env/

# ── OS ──
.DS_Store
Thumbs.db

# ── Editors ──
.vscode/
.idea/
.claude/
