        椺丗  乮儕僋僄僗僩俶俷丏俉侾俫乯

	S81::
		DW	TIMB81				; voice top addr.
	
		DB	6,3,TP81,DL81			; FM use ch,PSG,use ch
							; base,delay counter
		DEFW	TAB81D				; rythm table pointer
		DEFB	FB81D,FA81D			; bias,volm
	
		DEFW	TAB810				; FM 1ch table pointer
		DEFB	FB81M,FA81M			; bias,volm
	
		DEFW	TAB811				; FM 2ch table pointer
		DEFB	FB81B,FA81B                     ; bias,volm
	
		DEFW	TAB812				; FM 3ch table pointer
		DEFB	FB81K1,FA81K1                   ; bias,volm
	
		DEFW	TAB813				; FM 4ch table pointer
		DEFB	FB81K2,FA81K2                   ; bias,volm
	
		DEFW	TAB814				; FM 5ch table pointer
		DEFB	FB81K3,FA81K3                   ; bias,volm
	
		DEFW	TAB810P				; PSG 1ch table pointer
		DEFB	PB81M,PA81M,PV81M,PE81M         ; bias,volm,vibr,enve
	
		DEFW	TAB811P				; PSG 2ch table pointer
		DEFB	PB81B,PA81B,PV81B,PE81B         ; bias,volm,vibr,enve
	
		DEFW	TAB812P				; PSG 3ch table pointer
		DEFB	PB81K,PA81K,PV81K,PE81K         ; bias,volm,vibr,enve
	
	TAB810::
		DB	C3,L8,.........
	
		
	
	TIMB81::
	;----------------< Piano >-------------------
	fev8100::
		CNF	4,5			; algorithm , feedback
		MD	1,6,3,0,1,0,3,3		; multiple , detune
		RSAR	1,31,2,20,1,31,2,20	; key scale , attack rate
		D1R	5,5,5,7			; decay rate
		D2R	2,2,2,2 		; sustain rate
		RRL	15,1,15,6,15,1,15,10	; release rate , sustain level
		TL	30,0,30,0		; total level
	;----------------< Bass >-------------------
	fev8101::
		CNF	2,7
		MD	4,0,2,0,8,0,4,0
		RSAR	0,31,0,31,0,31,0,31
