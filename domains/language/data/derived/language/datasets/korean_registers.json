[
  {"id": "conv_01", "register": "conversational", "text": "야，나중에 오면 자리 잡아줄게。"},
  {"id": "conv_02", "register": "conversational", "text": "뭐 하는지 모르겠는데，나올 때 전화해。"},
  {"id": "conv_03", "register": "conversational", "text": "있잖아，나 늦게 도착하니까 먼저 시작해。"},
  {"id": "conv_04", "register": "conversational", "text": "시장 가는 거야，아니면 여기 있을 거야？"},
  {"id": "formal_01", "register": "formal", "text": "관심 가져 주셔서 감사합니다。추가 문의 사항이 있으시면 언제든지 연락해 주시기 바랍니다。"},
  {"id": "formal_02", "register": "formal", "text": "신청서는 공고에 명시된 기준에 따라 검토될 예정입니다。"},
  {"id": "formal_03", "register": "formal", "text": "해당 절차는 다음 주 월요일부터 시행됨을 알려 드립니다。"},
  {"id": "formal_04", "register": "formal", "text": "문제가 발생한 경우 해당 서류를 서면으로 제출하시기 바랍니다。"},
  {"id": "narrative_01", "register": "narrative", "text": "개들이 광장 옆에서 잠든 사이，마을에 비가 내렸다。"},
  {"id": "narrative_02", "register": "narrative", "text": "문을 열었을 때，텅 빈 복도에서 빛이 흔들리고 있었다。"},
  {"id": "narrative_03", "register": "narrative", "text": "기차는 새벽에 떠나，골짜기의 하얀 집들을 뒤에 남겨두었다。"},
  {"id": "narrative_04", "register": "narrative", "text": "아무도 말하지 않았지만，그 밤이 모든 것을 바꿀 것이라는 걸 모두 알고 있었다。"}
]
