{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Helix KB Object",
  "type": "object",
  "required": ["id", "type", "statement", "assumptions", "falsifiers", "status", "references"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "statement": {
      "type": "string"
    },
    "assumptions": {
      "type": "array"
    },
    "falsifiers": {
      "type": "array"
    },
    "status": {
      "type": "string",
      "enum": ["CAPTURE", "STRESS_TESTED", "COMPRESSED", "DEPRECATED"]
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
