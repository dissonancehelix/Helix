{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Helix KB Object",
  "type": "object",
  "required": [
    "id",
    "type",
    "statement",
    "assumptions",
    "falsifiers",
    "status",
    "references"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "statement": {
      "type": "string"
    },
    "assumptions": {
      "type": "array"
    },
    "falsifiers": {
      "type": "array"
    },
    "status": {
      "type": "string",
      "enum": [
        "CAPTURE",
        "STRESS_TESTED",
        "COMPRESSED",
        "DEPRECATED"
      ]
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stability_class": {
      "type": "string",
      "enum": [
        "BARRIER",
        "THROUGHPUT",
        "CRITICAL",
        "TOPOLOGICAL",
        "NOISE_CONSTRUCTIVE",
        "HYBRID",
        "UNCLASSIFIED"
      ],
      "description": "kernel-002 mechanism class. HYBRID = multiple classes operative. UNCLASSIFIED = no class formally operationalizable, or persistence_type is PATTERN."
    },
    "persistence_type": {
      "type": "string",
      "enum": [
        "STATE",
        "PATTERN"
      ],
      "description": "STATE: persistence of a specific structural configuration. PATTERN: persistence of a dynamical attractor or statistical signature (out of scope for kernel-002)."
    },
    "mechanism_formalism": {
      "type": "string",
      "enum": [
        "TST",
        "ISS",
        "RG",
        "TOPO",
        "NOISE",
        "OTHER"
      ],
      "description": "Primary mathematical formalism: TST=Transition State Theory (Class A), ISS=Input-to-State Stability (Class B), RG=Renormalization Group (Class C), TOPO=topological field theory (Class D), NOISE=stochastic noise-induced transitions (Class E), OTHER=multiple or none."
    },
    "scope_guard": {
      "type": "string",
      "description": "Explicit statement of what the claim does NOT cover and where metaphorical extensions are invalid."
    },
    "diagnostics": {
      "description": "Diagnostic indicators for the stability class; may be an array of strings or a structured object.",
      "not": {
        "type": "null"
      }
    },
    "class_countermodels": {
      "type": "array",
      "description": "Countermodels testing the stability class assignment."
    },
    "transition_rules": {
      "type": "array",
      "description": "Rules governing transitions between stability classes."
    },
    "hybrid_rules": {
      "type": "array",
      "description": "Rules for HYBRID class composition and dominance."
    },
    "decay_chain": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Ordered lineage of this claim, oldest first, newest last."
    },
    "observable_metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "estimator",
          "units_or_none"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "THERMODYNAMIC_ENERGY",
              "INFORMATION_METRIC",
              "TOPOLOGICAL_INVARIANT",
              "ECONOMIC_COST",
              "CONTROL_GAIN",
              "QUERY_COMPLEXITY",
              "POPULATION_FRACTION",
              "CORRELATION_LENGTH",
              "ENTROPY_PRODUCTION",
              "CUSTOM"
            ]
          },
          "estimator": {
            "type": "string"
          },
          "units_or_none": {
            "type": "string"
          },
          "threshold_value": {
            "type": "number"
          },
          "threshold_type": {
            "type": "string",
            "enum": [
              "MARGIN",
              "BASIN",
              "CAPACITY"
            ]
          },
          "projection_operator_id": {
            "type": "string"
          },
          "confidence_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}