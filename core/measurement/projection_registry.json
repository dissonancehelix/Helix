{
    "projectors": [
        {
            "id": "dimensionless_ratio",
            "description": "Simple ratio of two quantities with matching units",
            "inputs": [
                "numerator",
                "denominator"
            ],
            "formula": "numerator / denominator",
            "unit_constraint": "MATCHING",
            "invertible": true
        },
        {
            "id": "log_intensity",
            "description": "Logarithmic scaling of intensity vs baseline",
            "inputs": [
                "value",
                "baseline"
            ],
            "formula": "log10(value / baseline)",
            "unit_constraint": "MATCHING",
            "invertible": true
        },
        {
            "id": "normalized_entropy_gain",
            "description": "Change in entropy over maximum possible entropy",
            "inputs": [
                "h_delta",
                "h_max"
            ],
            "formula": "h_delta / h_max",
            "unit_constraint": "MATCHING",
            "invertible": false
        },
        {
            "id": "e_ratio",
            "description": "Activation energy vs thermal/noise floor",
            "inputs": [
                "e_a",
                "delta"
            ],
            "formula": "e_a / delta",
            "unit_constraint": "MATCHING",
            "invertible": true
        }
    ]
}