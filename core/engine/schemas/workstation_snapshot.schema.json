{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/engine/schemas/workstation_snapshot.schema.json",
  "title": "Workstation Snapshot",
  "description": "Output contract for core/tools/workstation_bridge/workstation_snapshot.py.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "repo_root",
    "mode",
    "sources",
    "top_level_inventory",
    "files_scanned",
    "bytes_scanned",
    "warnings"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp."
    },
    "repo_root": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["shallow", "deep"]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "exists", "files", "bytes", "skipped"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "exists": { "type": "boolean" },
          "files": { "type": "integer", "minimum": 0 },
          "bytes": { "type": "integer", "minimum": 0 },
          "skipped": { "type": "boolean" },
          "skipped_reason": { "type": "string" }
        }
      }
    },
    "top_level_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "type": "string", "enum": ["file", "dir"] },
          "has_readme": { "type": "boolean" }
        }
      }
    },
    "files_scanned": { "type": "integer", "minimum": 0 },
    "bytes_scanned": { "type": "integer", "minimum": 0 },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

